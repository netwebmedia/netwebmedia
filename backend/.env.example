DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=America/Santiago

# Leave these blank to use SQLite for local development.
POSTGRES_DB=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=True

# --- Security ---
# Comma-separated list of allowed CORS origins (e.g. https://app.netwebmedia.com)
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Comma-separated CSRF trusted origins
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100
MAX_REQUEST_BODY_SIZE=2097152

# DRF throttle rates
THROTTLE_RATE_ANON=20/minute
THROTTLE_RATE_USER=200/minute
